{
  "name": "Diesel Heater Serial Bridge",
  "version": "1.0.0",
  "slug": "diesel_serial_bridge",
  "description": "Bridges a diesel heater's serial port to MQTT topics under van/diesel/*",
  "init": false,
  "arch": [
    "aarch64",
    "amd64"
  ],
  "uart": true,
  "options": {
    "mqtt_broker": "core-mosquitto",
    "mqtt_port": 1883,
    "mqtt_user": "",
    "mqtt_password": "",
    "serial_port": "/dev/ttyUSB0",
    "serial_baud": 115200
  },
  "schema": {
    "mqtt_broker": "str",
    "mqtt_port": "port",
    "mqtt_user": "str?",
    "mqtt_password": "password?",
    "serial_port": "str",
    "serial_baud": "int"
  }
}
